<view class="page">
  <view class="card">
    <view class="title">智能推荐</view>
    <view class="field">
      <text class="field-label">学习目标</text>
      <input class="input" data-field="goals" bindinput="onInput" placeholder="例如：人工智能与软件工程" />
    </view>
    <view class="field">
      <text class="field-label">偏好（逗号分隔）</text>
      <input class="input" data-field="preferences" bindinput="onInput" placeholder="例如：实践课程,周一" />
    </view>
    <view class="form-error" wx:if="{{error}}">{{error}}</view>
    <button class="primary-button" bindtap="submit" loading="{{busy}}" disabled="{{busy}}">生成推荐</button>
  </view>
  <async-state phase="{{phase}}" message="{{error || '暂无推荐'}}" bind:retry="retry">
    <view class="notice" wx:if="{{statusText}}">{{statusText}}</view>
    <view class="card recommendation" wx:for="{{session.items}}" wx:key="course_id">
      <view class="row-between">
        <view class="rank">#{{item.rank}}</view>
        <text class="decision {{item.eligibility.eligible ? 'eligible' : 'blocked'}}">{{item.eligibility.decision}}</text>
      </view>
      <view class="reason" wx:for="{{item.reasons}}" wx:key="*this">{{item}}</view>
      <view class="muted" wx:for="{{item.uncertainties}}" wx:key="*this">{{item}}</view>
      <button size="mini" data-id="{{item.course_id}}" bindtap="openCourse">查看课程</button>
    </view>
  </async-state>
</view>
