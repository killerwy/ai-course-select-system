# Copy to backend/.env for a Navicat/MySQL run. Never commit real secrets.
APP_STORAGE=mysql
DATABASE_URL=mysql+aiomysql://root:your_password@127.0.0.1:3306/course_selection?charset=utf8mb4
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
STUDENT_WEB_ORIGIN=http://localhost:5173
ADMIN_WEB_ORIGIN=http://localhost:5174

# Optional; an empty value keeps deterministic rule-based recommendations.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Optional local LlamaIndex RAG path.  The embedding model is loaded from
# HuggingFace Hub (HF_HOME) by model ID.  The vector index is persisted under
# the project storage directory and rebuilt when the course catalog fingerprint
# changes.
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_STORAGE_PATH=../storage/rag
RAG_TOP_K=8
RAG_DEVICE=cpu
